<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} · Pipelin" : "Pipelin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-screen overflow-hidden bg-white flex flex-col">
    <%= render "shared/nav" %>
    <%# flex-1 + min-h-0 lets this shrink below content size so only the inner scroll target scrolls %>
    <main class="flex-1 overflow-y-auto <%= yield :main_class %>">
      <div class="<%= content_for?(:main_inner) ? yield(:main_inner) : 'max-w-6xl mx-auto px-5 py-10' %>">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    </main>
  </body>
</html>
