<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} · Pipelin" : "Pipelin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <%= favicon_link_tag 'favicon.svg', rel: 'icon', type: 'image/svg+xml' %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-white flex flex-col">
    <%= render "shared/nav" %>
    <%#
      The body grows to fit the viewport (min-h-screen) and scrolls
      naturally when content overflows. The nav is position: sticky so
      it stays pinned to the top during scroll.
      The chat page overrides the <main> via content_for :main_class
      to have its own independent scroll area (main-chat).
    %>
    <main class="flex-1 <%= yield :main_class %>">
      <div class="<%= content_for?(:main_inner) ? yield(:main_inner) : 'max-w-6xl mx-auto px-5 py-10' %>">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    </main>
  </body>
</html>
