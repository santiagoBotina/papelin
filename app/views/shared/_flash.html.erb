<div id="flash" class="space-y-2 mb-6">
  <% if flash[:notice] %>
    <div role="alert" class="flex items-center justify-between gap-4 px-4 py-3 rounded-xl text-sm font-medium"
         style="background:#f0fdf4; border:1px solid #bbf7d0; color:#166534;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <%= flash[:notice] %>
      </div>
      <button onclick="this.closest('[role=alert]').remove()" class="text-green-400 hover:text-green-600 text-lg leading-none">&times;</button>
    </div>
  <% end %>
  <% [:alert, :error].each do |key| %>
    <% if flash[key] %>
      <div role="alert" class="flex items-center justify-between gap-4 px-4 py-3 rounded-xl text-sm font-medium"
           style="background:#fff1f2; border:1px solid #fecdd3; color:#9f1239;">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= flash[key] %>
        </div>
        <button onclick="this.closest('[role=alert]').remove()" class="text-rose-400 hover:text-rose-600 text-lg leading-none">&times;</button>
      </div>
    <% end %>
  <% end %>
  <% if flash[:info] %>
    <div role="alert" class="flex items-center justify-between gap-4 px-4 py-3 rounded-xl text-sm font-medium"
         style="background:#f5f3ff; border:1px solid #ddd6fe; color:#5b21b6;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= flash[:info] %>
      </div>
      <button onclick="this.closest('[role=alert]').remove()" class="text-violet-400 hover:text-violet-600 text-lg leading-none">&times;</button>
    </div>
  <% end %>
</div>
