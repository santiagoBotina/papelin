<% content_for :title, "Conversaciones" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Conversaciones</h1>
    <p class="page-subtitle">Haz preguntas sobre certificados y procesos de RRHH</p>
  </div>
  <%= link_to conversations_path, class: "btn btn-violet", data: { turbo_method: :post } do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Nueva conversación
  <% end %>
</div>

<% if @conversations.present? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @conversations.each do |conversation| %>
      <%= link_to conversation_path(conversation), class: "card card-link block p-5 group" do %>
        <div id="<%= dom_id(conversation) %>">
          <div class="flex items-start justify-between gap-2 mb-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#ede9fe;">
              <svg class="w-4 h-4" style="color:#7c3aed;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <span style="font-size:11.5px; color:#a1a1aa;"><%= l(conversation.created_at, format: :short) %></span>
          </div>
          <h3 class="font-medium mb-1.5" style="font-size:14px; color:#18181b; line-height:1.35;">
            <%= conversation.title.presence || "Nueva conversación" %>
          </h3>
          <p style="font-size:13px; color:#71717a; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
            <%= conversation.messages.last&.content&.truncate(90) || "Sin mensajes aún" %>
          </p>
          <div class="mt-3 pt-3" style="border-top:1px solid #f4f4f5;">
            <span class="badge <%= conversation.active? ? 'badge-ready' : 'badge-pending' %>">
              <%= conversation.active? ? "Activa" : "Archivada" %>
            </span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if defined?(@pagy) && @pagy %>
    <div class="mt-8"><%== pagy_nav(@pagy) if @pagy.pages > 1 %></div>
  <% end %>
<% else %>
  <div class="empty-state">
    <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <p class="empty-state-title">Aún no tienes conversaciones</p>
    <p class="empty-state-desc">Inicia una para hacer preguntas sobre tus certificados</p>
    <%= link_to conversations_path, class: "btn btn-violet", data: { turbo_method: :post } do %>
      Empezar ahora
    <% end %>
  </div>
<% end %>
