<% content_for :title, "Mis Conversaciones" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Mis Conversaciones</h1>
  <%= link_to "Nueva Conversación", conversations_path,
              class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors",
              data: { turbo_method: :post } %>
</div>

<% if @conversations.present? %>
  <div class="space-y-3">
    <% @conversations.each do |conversation| %>
      <%= link_to conversation_path(conversation), class: "block" do %>
        <div id="<%= dom_id(conversation) %>" class="bg-white rounded-xl border border-gray-200 p-4 hover:border-blue-300 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between">
            <h3 class="font-medium text-gray-900">
              <%= conversation.title.presence || "Nueva conversación" %>
            </h3>
            <span class="text-xs text-gray-400">
              <%= l(conversation.created_at, format: :short) %>
            </span>
          </div>
          <p class="text-sm text-gray-500 mt-1 line-clamp-1">
            <%= conversation.messages.last&.content&.truncate(80) || "Sin mensajes" %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if defined?(@pagy) && @pagy %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-16">
    <p class="text-gray-500 text-lg mb-4">Aún no tienes conversaciones.</p>
    <%= link_to "Iniciar una nueva conversación", conversations_path,
                class: "text-blue-600 hover:text-blue-700 font-medium",
                data: { turbo_method: :post } %>
  </div>
<% end %>
