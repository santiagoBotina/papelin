<div class="min-h-[calc(100vh-56px)] flex items-center justify-center px-4 -mt-10">
  <div class="w-full max-w-sm">

    <%# Brand mark %>
    <div class="text-center mb-10">
      <p class="pipelin-logo text-3xl mb-2">Pipe<span>lin</span></p>
      <p class="text-sm" style="color:#71717a;">Asistente de certificados y documentos</p>
    </div>

    <div class="card p-7">
      <h2 class="font-display text-xl mb-6" style="font-style:italic; color:#18181b;">Bienvenido de nuevo</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-4">
          <%= f.label :email, "Correo electrónico", class: "input-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
        </div>

        <div class="mb-5">
          <%= f.label :password, "Contraseña", class: "input-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center justify-between mb-6">
            <label class="flex items-center gap-2 cursor-pointer select-none" style="font-size:13px; color:#52525b;">
              <%= f.check_box :remember_me, style: "accent-color:#7c3aed;" %>
              Recordarme
            </label>
            <% if devise_mapping.recoverable? %>
              <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name),
                  style: "font-size:13px; color:#7c3aed; font-weight:500;" %>
            <% end %>
          </div>
        <% end %>

        <%= f.submit "Iniciar sesión", class: "btn btn-violet btn-lg w-full mt-1", style: "width:100%;" %>
      <% end %>
    </div>

    <p class="text-center mt-5" style="font-size:12.5px; color:#a1a1aa;">
      ¿Problemas para acceder? Contacta a tu administrador de RRHH.
    </p>
  </div>
</div>
