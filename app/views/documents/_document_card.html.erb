<%# local: document %>
<div id="<%= dom_id(document) %>"
     class="bg-white rounded-xl border border-gray-200 p-4 flex flex-col gap-3 hover:border-blue-200 hover:shadow-sm transition-all">
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-medium text-gray-900 text-sm leading-tight"><%= document.title %></h3>
    <span class="<%= status_badge_classes(document.status) %> text-xs px-2 py-0.5 rounded-full whitespace-nowrap">
      <%= document.status.humanize %>
    </span>
  </div>
  <% if document.description.present? %>
    <p class="text-sm text-gray-500 line-clamp-2"><%= document.description %></p>
  <% end %>
  <div class="flex items-center justify-between text-xs text-gray-400 mt-auto pt-2 border-t border-gray-100">
    <span><%= document.doc_type.humanize %></span>
    <span><%= document.chunks_count %> secciones</span>
  </div>
</div>
