<% content_for :title, "Documentos" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Documentos</h1>
    <p class="page-subtitle">Base de conocimiento para el asistente de IA</p>
  </div>
  <% if current_user&.admin? %>
    <%= link_to new_document_path, class: "btn btn-emerald" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Subir documento
    <% end %>
  <% end %>
</div>

<div id="documents">
  <% if @documents.present? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <%= render @documents %>
    </div>
    <% if defined?(@pagy) && @pagy %>
      <div class="mt-8"><%== pagy_nav(@pagy) if @pagy.pages > 1 %></div>
    <% end %>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p class="empty-state-title">No hay documentos disponibles</p>
      <p class="empty-state-desc">Los administradores pueden subir documentos PDF, DOCX o TXT</p>
    </div>
  <% end %>
</div>
