<% content_for :title, "Base de Conocimiento" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Base de Conocimiento</h1>
  <% if current_user&.admin? %>
    <%= link_to "Subir Documento", new_document_path,
                class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
  <% end %>
</div>

<div id="documents">
  <% if @documents.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <%= render @documents %>
    </div>

    <% if defined?(@pagy) && @pagy %>
      <div class="mt-6">
        <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16">
      <p class="text-gray-500 text-lg">No hay documentos disponibles aún.</p>
    </div>
  <% end %>
</div>
