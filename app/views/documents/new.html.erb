<% content_for :title, "Subir documento" %>

<div class="max-w-2xl">
  <div class="page-header">
    <div>
      <h1 class="page-title">Subir documento</h1>
      <p class="page-subtitle">PDF, Word, Markdown o texto plano · máx. 20 MB</p>
    </div>
    <%= link_to documents_path, class: "btn btn-ghost" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Cancelar
    <% end %>
  </div>

  <div class="card p-7">
    <%= form_with model: @document do |f| %>
      <% if @document.errors.any? %>
        <div class="mb-5 p-4 rounded-xl" style="background:#fff1f2; border:1px solid #fecdd3;">
          <p style="font-size:13px; font-weight:600; color:#9f1239; margin-bottom:6px;">
            <%= pluralize(@document.errors.count, "error") %> impidieron guardar el documento:
          </p>
          <ul style="font-size:13px; color:#be123c; list-style:disc; padding-left:18px;">
            <% @document.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div class="sm:col-span-2">
          <%= f.label :title, "Título del documento", class: "input-label" %>
          <%= f.text_field :title, class: "input", placeholder: "Ej. Manual de Políticas de RRHH 2024" %>
        </div>

        <div>
          <%= f.label :doc_type, "Tipo", class: "input-label" %>
          <%= f.select :doc_type,
                options_for_select(Document.doc_types.keys.map { |t| [t.humanize, t] }),
                {},
                class: "input" %>
        </div>

        <div>
          <%= f.label :cert_type, "Tipo de certificado (opcional)", class: "input-label" %>
          <%= f.select :cert_type,
                options_for_select(
                  [['— Ninguno (documento general) —', '']] +
                  CertificateRequest.cert_types.keys.map { |t| [t.humanize, t] },
                  @document.cert_type
                ),
                {},
                class: "input" %>
          <p style="font-size:11.5px; color:#a1a1aa; margin-top:4px;">
            Si se establece, habilita ese tipo de certificado para que los empleados lo soliciten.
          </p>
        </div>

        <div>
          <label class="input-label">Estado inicial</label>
          <div class="input flex items-center gap-2 cursor-default" style="color:#71717a;">
            <span class="badge badge-pending">Pendiente</span>
            <span style="font-size:13px;">— se procesará automáticamente</span>
          </div>
        </div>

        <div class="sm:col-span-2">
          <%= f.label :description, "Descripción (opcional)", class: "input-label" %>
          <%= f.text_area :description, rows: 3, class: "input", placeholder: "Breve descripción del contenido del documento…" %>
        </div>
      </div>

      <%# Drop zone %>
      <div data-controller="upload" class="mb-6">
        <label class="input-label">Archivo</label>
        <div data-upload-target="dropzone"
             data-action="dragover->upload#dragover dragleave->upload#dragleave drop->upload#drop"
             style="border:2px dashed #e4e4e7; border-radius:12px; padding:32px 24px; text-align:center; transition:border-color .15s, background .15s; cursor:pointer;"
             onmouseover="this.style.borderColor='#059669'; this.style.background='#f0fdf4';"
             onmouseout="this.style.borderColor='#e4e4e7'; this.style.background='transparent';">
          <div style="width:44px; height:44px; background:#f0fdf4; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
            <svg class="w-5 h-5" style="color:#059669;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
          </div>
          <p style="font-size:14px; font-weight:500; color:#18181b; margin-bottom:4px;">Arrastra tu archivo aquí</p>
          <p style="font-size:13px; color:#a1a1aa; margin-bottom:12px;">PDF, DOCX, MD o TXT — hasta 20 MB</p>
          <%= f.file_field :file,
                accept: ".pdf,.docx,.txt,.md",
                data: { "upload-target": "fileInput", action: "change->upload#fileSelected" },
                style: "font-size:13px; color:#71717a;",
                class: "cursor-pointer" %>
        </div>
        <div data-upload-target="preview" class="hidden mt-3 flex items-center gap-2 px-4 py-2.5 rounded-lg" style="background:#f0fdf4; border:1px solid #bbf7d0;">
          <svg class="w-4 h-4 shrink-0" style="color:#16a34a;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span style="font-size:13px; color:#15803d; font-weight:500;">Archivo seleccionado:</span>
          <span data-upload-target="filename" style="font-size:13px; color:#15803d;"></span>
        </div>
      </div>

      <%= f.submit "Subir documento", class: "btn btn-emerald btn-lg", style: "width:100%;" %>
    <% end %>
  </div>
</div>
