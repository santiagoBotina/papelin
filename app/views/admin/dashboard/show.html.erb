<% content_for :title, "Panel Admin" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Panel de administración</h1>
    <p class="page-subtitle">Resumen del sistema · <%= Date.current.strftime("%B %Y").capitalize %></p>
  </div>
  <div class="flex gap-2">
    <%= link_to admin_users_path, class: "btn btn-ghost btn-sm" do %>
      Gestionar usuarios
    <% end %>
    <%= link_to admin_documents_path, class: "btn btn-ghost btn-sm" do %>
      Ver documentos
    <% end %>
  </div>
</div>

<%# Stats grid %>
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
  <% [
    { label: "Documentos",     value: @documents_count, color: "#4f46e5" },
    { label: "Listos",         value: @ready_count,     color: "#059669" },
    { label: "Procesando",     value: @pending_count,   color: "#d97706" },
    { label: "Con errores",    value: @failed_count,    color: "#e11d48" },
    { label: "Usuarios",       value: @users_count,     color: "#7c3aed" },
    { label: "Conversaciones", value: Conversation.active.count, color: "#0284c7" },
  ].each do |stat| %>
    <div class="card stat-card">
      <p class="stat-value" style="color:<%= stat[:color] %>;"><%= stat[:value] %></p>
      <p class="stat-label"><%= stat[:label] %></p>
    </div>
  <% end %>
</div>

<%# Recent documents table %>
<div class="flex items-center justify-between mb-4">
  <p class="section-label">Documentos recientes</p>
  <%= link_to "Ver todos →", admin_documents_path, style: "font-size:13px; color:#7c3aed; font-weight:500;" %>
</div>

<% if @documents.present? %>
  <div class="card overflow-hidden">
    <table class="data-table">
      <thead>
        <tr>
          <th>Título</th>
          <th>Estado</th>
          <th>Secciones</th>
          <th>Subido por</th>
          <th>Hace</th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |doc| %>
          <tr>
            <td>
              <%= link_to doc.title, admin_document_path(doc),
                    style: "font-weight:500; color:#18181b;" %>
            </td>
            <td><span class="badge badge-<%= doc.status %>"><%= doc.status.humanize %></span></td>
            <td style="color:#71717a;"><%= doc.chunks_count %></td>
            <td style="color:#71717a;"><%= doc.uploaded_by.display_name %></td>
            <td style="color:#a1a1aa;"><%= time_ago_in_words(doc.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state">
    <p class="empty-state-title">No hay documentos aún</p>
  </div>
<% end %>
