<% content_for :title, "Administrar Documentos" %>

<% if notice.present? %>
  <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">
    <%= notice %>
  </div>
<% end %>

<% if alert.present? %>
  <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
    <%= alert %>
  </div>
<% end %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Administrar Documentos</h1>
  <%= link_to "Subir Documento", new_document_path,
              class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="text-left py-3 px-4 font-medium text-gray-600">Título</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Tipo</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Tipo cert.</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Estado</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Secciones</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Subido por</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Fecha</th>
        <th class="text-right py-3 px-4 font-medium text-gray-600">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @documents.each do |doc| %>
        <tr id="<%= dom_id(doc) %>" class="border-b border-gray-100 hover:bg-gray-50">
          <td class="py-3 px-4 font-medium text-gray-900"><%= doc.title %></td>
          <td class="py-3 px-4 text-gray-600"><%= doc.doc_type.humanize %></td>
          <td class="py-3 px-4">
            <% if doc.cert_type.present? %>
              <span class="bg-violet-100 text-violet-700 text-xs px-2 py-0.5 rounded-full"><%= doc.cert_type.humanize %></span>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </td>
          <td class="py-3 px-4">
            <span class="<%= status_badge_classes(doc.status) %> text-xs px-2 py-0.5 rounded-full"><%= doc.status.humanize %></span>
          </td>
          <td class="py-3 px-4 text-gray-500"><%= doc.chunks_count %></td>
          <td class="py-3 px-4 text-gray-500"><%= doc.uploaded_by.display_name %></td>
          <td class="py-3 px-4 text-gray-500"><%= l(doc.created_at, format: :short) %></td>
          <td class="py-3 px-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Ver", admin_document_path(doc),
                          class: "text-sm text-gray-600 hover:text-gray-900 font-medium" %>
              <%= link_to "Editar", edit_admin_document_path(doc),
                          class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
              <% if doc.failed? %>
                <%= button_to reingest_admin_document_path(doc), method: :post,
                              class: "text-sm font-medium text-amber-600 hover:text-amber-800 px-2 py-1 rounded-md hover:bg-amber-50 transition-colors",
                              title: "Reintentar ingesta" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
