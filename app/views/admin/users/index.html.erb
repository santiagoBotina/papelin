<% content_for :title, "Usuarios" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Usuarios</h1>
    <p class="page-subtitle"><%= @users.count %> usuarios registrados</p>
  </div>
  <%= link_to new_admin_user_path, class: "btn btn-violet" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Nuevo usuario
  <% end %>
</div>

<div class="card overflow-hidden">
  <table class="data-table">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>ID Empleado</th>
        <th>Rol</th>
        <th>Registrado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td>
            <div class="flex items-center gap-2.5">
              <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold shrink-0"
                   style="background:<%= user.admin? ? '#f5f3ff' : '#f0fdf4' %>; color:<%= user.admin? ? '#7c3aed' : '#15803d' %>;">
                <%= user.first_name[0]&.upcase %><%= user.last_name[0]&.upcase %>
              </div>
              <%= link_to user.display_name, admin_user_path(user), style: "font-weight:500; color:#18181b;" %>
            </div>
          </td>
          <td style="color:#71717a;"><%= user.email %></td>
          <td style="font-family:monospace; font-size:12.5px; color:#71717a;"><%= user.employee_id %></td>
          <td>
            <span class="badge" style="background:<%= user.admin? ? '#f5f3ff' : '#f4f4f5' %>; color:<%= user.admin? ? '#5b21b6' : '#52525b' %>;">
              <%= user.role.humanize %>
            </span>
          </td>
          <td style="color:#a1a1aa;"><%= l(user.created_at, format: :short) %></td>
          <td>
            <div class="flex items-center gap-2">
              <%= link_to "Editar", edit_admin_user_path(user), class: "btn btn-ghost btn-sm" %>
              <%= button_to "Eliminar", admin_user_path(user), method: :delete,
                    data: { turbo_confirm: "¿Eliminar a #{user.display_name}? Esta acción no se puede deshacer." },
                    class: "btn btn-rose btn-sm" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
