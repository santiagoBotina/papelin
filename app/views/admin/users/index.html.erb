<% content_for :title, "Administrar Usuarios" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Usuarios</h1>
  <%= link_to "Nuevo Usuario", new_admin_user_path,
              class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="text-left py-3 px-4 font-medium text-gray-600">Nombre</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Email</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">ID Empleado</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Rol</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Registrado</th>
        <th class="text-left py-3 px-4 font-medium text-gray-600">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="py-3 px-4">
            <%= link_to user.display_name, admin_user_path(user), class: "font-medium text-blue-600 hover:text-blue-800" %>
          </td>
          <td class="py-3 px-4 text-gray-600"><%= user.email %></td>
          <td class="py-3 px-4 text-gray-500"><%= user.employee_id %></td>
          <td class="py-3 px-4">
            <span class="<%= user.admin? ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %> text-xs px-2 py-0.5 rounded-full">
              <%= user.role.humanize %>
            </span>
          </td>
          <td class="py-3 px-4 text-gray-500"><%= l(user.created_at, format: :short) %></td>
          <td class="py-3 px-4">
            <div class="flex items-center gap-2">
              <%= link_to "Editar", edit_admin_user_path(user), class: "text-blue-600 hover:text-blue-800 text-xs font-medium" %>
              <%= button_to "Eliminar", admin_user_path(user), method: :delete,
                            data: { turbo_confirm: "¿Estás seguro?" },
                            class: "text-red-600 hover:text-red-800 text-xs font-medium" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
