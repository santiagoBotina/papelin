<% content_for :title, "Usuario: #{@user.display_name}" %>

<div class="max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900"><%= @user.display_name %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Editar", edit_admin_user_path(@user), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
      <%= link_to "Volver", admin_users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <dl class="space-y-4">
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Nombre completo</dt>
        <dd class="text-sm text-gray-900 font-medium"><%= @user.display_name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Email</dt>
        <dd class="text-sm text-gray-900"><%= @user.email %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">ID Empleado</dt>
        <dd class="text-sm text-gray-900"><%= @user.employee_id %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Rol</dt>
        <dd class="text-sm">
          <span class="<%= @user.admin? ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %> text-xs px-2 py-0.5 rounded-full">
            <%= @user.role.humanize %>
          </span>
        </dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Miembro desde</dt>
        <dd class="text-sm text-gray-900"><%= l(@user.created_at, format: :long) %></dd>
      </div>
    </dl>
  </div>

  <!-- Certificate requests -->
  <% cert_requests = @user.certificate_requests.recent %>
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Solicitudes de certificados</h2>
      <%= link_to "Ver todas", admin_certificate_requests_path(user_id: @user.id),
            class: "text-sm text-purple-600 hover:text-purple-800 font-medium" %>
    </div>
    <% if cert_requests.any? %>
      <div class="space-y-2">
        <% cert_requests.first(5).each do |cr| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
            <div>
              <span style="font-size:13px; font-family:monospace; font-weight:600; color:#7c3aed;"><%= cr.reference_number %></span>
              <span class="text-xs text-gray-500 ml-2"><%= cr.cert_type.humanize %></span>
            </div>
            <div class="flex items-center gap-3">
              <% if cr.generated_file.attached? %>
                <span class="text-xs text-green-600 font-medium">✓ Certificado adjunto</span>
              <% end %>
              <span class="badge badge-<%= cr.status %>" style="font-size:11px;"><%= cr.human_status %></span>
              <%= link_to "Gestionar", admin_certificate_request_path(cr),
                    class: "text-xs text-purple-600 hover:text-purple-800 font-medium" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">Sin solicitudes registradas</p>
    <% end %>
  </div>

  <div class="flex items-center gap-4">
    <%= button_to "Eliminar Usuario", admin_user_path(@user), method: :delete,
                  data: { turbo_confirm: "¿Estás seguro de eliminar este usuario?" },
                  class: "text-red-600 hover:text-red-800 text-sm font-medium" %>
  </div>
</div>
