<% content_for :title, "Solicitud #{@certificate_request.reference_number}" %>

<div class="max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @certificate_request.reference_number %></h1>
      <p class="text-sm text-gray-500">
        <%= @certificate_request.cert_type.humanize %> —
        <%= link_to @certificate_request.user.display_name, admin_user_path(@certificate_request.user),
              class: "text-purple-600 hover:text-purple-800" %>
      </p>
    </div>
    <%= link_to "← Volver", admin_certificate_requests_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <!-- Info card -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Detalles</h2>
    <dl class="space-y-3">
      <div class="flex justify-between text-sm">
        <dt class="text-gray-500">Estado actual</dt>
        <dd>
          <% if @certificate_request.overdue? %>
            <span class="badge badge-failed">Vencida</span>
          <% else %>
            <span class="badge badge-<%= @certificate_request.status %>"><%= @certificate_request.human_status %></span>
          <% end %>
        </dd>
      </div>
      <div class="flex justify-between text-sm">
        <dt class="text-gray-500">Solicitado</dt>
        <dd class="text-gray-900"><%= l(@certificate_request.requested_at, format: :long) %></dd>
      </div>
      <% if @certificate_request.expected_ready_at %>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Fecha estimada</dt>
          <dd class="text-gray-900"><%= l(@certificate_request.expected_ready_at, format: :long) %></dd>
        </div>
      <% end %>
      <% if @certificate_request.notes.present? %>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Notas</dt>
          <dd class="text-gray-700 max-w-xs text-right"><%= @certificate_request.notes %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <!-- Upload certificate form -->
  <%= form_with url: admin_certificate_request_path(@certificate_request), method: :patch,
                multipart: true, class: "bg-white rounded-xl border border-gray-200 p-6 mb-6" do |f| %>
    <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Subir certificado</h2>

    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Archivo del certificado</label>
        <% if @certificate_request.generated_file.attached? %>
          <div class="flex items-center gap-3 p-3 bg-green-50 border border-green-200 rounded-lg mb-3">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-green-800 truncate"><%= @certificate_request.generated_file.filename %></p>
              <p class="text-xs text-green-600"><%= number_to_human_size(@certificate_request.generated_file.byte_size) %></p>
            </div>
            <%= link_to "Descargar", rails_blob_path(@certificate_request.generated_file, disposition: "attachment"),
                        class: "text-sm text-green-700 font-medium hover:text-green-900 shrink-0" %>
          </div>
          <p class="text-xs text-gray-500 mb-2">Subir un nuevo archivo reemplazará el actual.</p>
        <% end %>
        <%= f.file_field :generated_file,
              class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 cursor-pointer" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Actualizar estado</label>
        <%= f.select :status,
              CertificateRequest.statuses.keys.map { |s| [s.humanize, s] },
              { selected: @certificate_request.status },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" %>
      </div>
    </div>

    <div class="mt-5 flex justify-end">
      <%= f.submit "Guardar cambios",
            class: "bg-purple-600 hover:bg-purple-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
