<% content_for :title, "Tipos de certificado" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Tipos de certificado</h1>
    <p class="page-subtitle">Administra los tipos de certificado disponibles para los empleados</p>
  </div>
  <%= link_to new_admin_certificate_type_path, class: "btn btn-violet" do %>
    <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Nuevo tipo
  <% end %>
</div>

<% if @certificate_types.any? %>
  <div class="card overflow-hidden">
    <table class="data-table">
      <thead>
        <tr>
          <th>Tipo</th>
          <th>Descripción</th>
          <th class="text-center">Estado</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @certificate_types.each do |ct| %>
          <tr>
            <td>
              <div style="font-weight:500; color:#18181b;"><%= ct.label %></div>
              <div style="font-size:12px; color:#a1a1aa; margin-top:1px;"><%= ct.key %></div>
            </td>
            <td style="color:#52525b; max-width:320px;"><%= ct.description %></td>
            <td class="text-center">
              <% if ct.active? %>
                <span class="badge badge-ready">Habilitado</span>
              <% else %>
                <span class="badge badge-pending">Deshabilitado</span>
              <% end %>
            </td>
            <td class="text-right">
              <div class="flex items-center justify-end gap-1.5">
                <%= link_to edit_admin_certificate_type_path(ct), class: "btn btn-ghost btn-sm" do %>
                  <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                  Editar
                <% end %>

                <%= button_to admin_certificate_type_path(ct),
                      method: :patch,
                      params: { certificate_type: { active: !ct.active? } },
                      class: "btn btn-sm #{ct.active? ? 'btn-ghost' : 'btn-emerald'}" do %>
                  <% if ct.active? %>
                    Deshabilitar
                  <% else %>
                    Habilitar
                  <% end %>
                <% end %>

                <% if ct.associated_requests? %>
                  <span class="btn btn-sm" style="opacity:0.3; cursor:not-allowed; background:transparent; color:#a1a1aa; border:1px solid #e4e4e7;" title="No se puede eliminar — hay solicitudes asociadas">
                    Eliminar
                  </span>
                <% else %>
                  <%= button_to admin_certificate_type_path(ct),
                        method: :delete,
                        class: "btn btn-sm btn-ghost",
                        style: "color:#e11d48;",
                        data: { turbo_confirm: "¿Eliminar \"#{ct.label}\"?" } do %>
                    Eliminar
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="section-label" style="margin-top:18px; margin-bottom:0;">
    Los tipos habilitados aparecen como opciones cuando un empleado solicita un certificado.
    Deshabilitar un tipo no afecta las solicitudes ya creadas.
  </p>
<% else %>
  <div class="card" style="padding:64px 24px; text-align:center;">
    <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <p class="empty-state-title">No hay tipos de certificado</p>
    <p class="empty-state-desc">Crea el primer tipo para que los empleados puedan solicitar certificados.</p>
    <%= link_to new_admin_certificate_type_path, class: "btn btn-violet" do %>
      <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Crear tipo
    <% end %>
  </div>
<% end %>
