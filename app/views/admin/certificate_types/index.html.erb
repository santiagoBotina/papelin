<% content_for :title, "Tipos de certificado" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Tipos de certificado</h1>
    <p class="page-subtitle">Habilita o deshabilita qué tipos pueden solicitar los empleados</p>
  </div>
</div>

<% if notice.present? %>
  <div style="margin-bottom:16px; padding:12px 16px; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; font-size:13px; color:#15803d;">
    <%= notice %>
  </div>
<% end %>

<div class="card overflow-hidden">
  <table class="data-table">
    <thead>
      <tr>
        <th>Tipo</th>
        <th>Descripción</th>
        <th style="text-align:center;">Estado</th>
        <th style="text-align:right;">Acción</th>
      </tr>
    </thead>
    <tbody>
      <% @certificate_types.each do |ct| %>
        <tr>
          <td>
            <span style="font-size:13.5px; font-weight:600; color:#18181b; font-family:monospace;"><%= ct.label %></span>
            <span style="display:block; font-size:11px; color:#a1a1aa; font-family:inherit; margin-top:2px;"><%= ct.key %></span>
          </td>
          <td style="font-size:13px; color:#52525b; max-width:280px;"><%= ct.description %></td>
          <td style="text-align:center;">
            <% if ct.active? %>
              <span class="badge badge-ready">Habilitado</span>
            <% else %>
              <span class="badge badge-pending">Deshabilitado</span>
            <% end %>
          </td>
          <td style="text-align:right;">
            <%= button_to admin_certificate_type_path(ct),
                  method: :patch,
                  params: { active: !ct.active? },
                  class: ct.active? ? "btn btn-sm" : "btn btn-violet btn-sm",
                  style: ct.active? ? "background:#fef2f2; color:#b91c1c; border:1px solid #fecaca;" : "" do %>
              <% if ct.active? %>
                <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                </svg>
                Deshabilitar
              <% else %>
                <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Habilitar
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p style="font-size:12px; color:#a1a1aa; margin-top:12px; line-height:1.5;">
  Los tipos habilitados aparecen como opciones cuando un empleado solicita un certificado.
  Deshabilitar un tipo no afecta las solicitudes ya creadas.
</p>
