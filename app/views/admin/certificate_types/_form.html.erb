<%# local: certificate_type %>
<%= form_with model: certificate_type, url: certificate_type.new_record? ? admin_certificate_types_path : admin_certificate_type_path(certificate_type),
              class: "space-y-6" do |f| %>
  <% if certificate_type.errors.any? %>
    <div style="background:#fff1f2; border:1px solid #fecdd3; color:#9f1239; border-radius:10px; padding:12px 16px; font-size:13px;">
      <ul style="list-style:disc; padding-left:18px; margin:0;">
        <% certificate_type.errors.full_messages.each do |msg| %>
          <li style="margin-bottom:2px;"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :key, "Clave interna", class: "input-label" %>
    <%= f.text_field :key,
          readonly: !certificate_type.new_record?,
          class: "input #{'readonly-input' unless certificate_type.new_record?}" %>
    <p style="font-size:12px; color:#a1a1aa; margin-top:5px;">Minúsculas y guiones bajos, ej. "payroll". No se puede cambiar después de crear.</p>
  </div>

  <div>
    <%= f.label :label, "Nombre", class: "input-label" %>
    <%= f.text_field :label, class: "input" %>
  </div>

  <div>
    <%= f.label :description, "Descripción", class: "input-label" %>
    <%= f.text_area :description, rows: 2, class: "input" %>
  </div>

  <label class="flex items-center gap-2.5" style="cursor:pointer;">
    <%= f.check_box :active, class: "toggle-checkbox" %>
    <span style="font-size:13.5px; font-weight:500; color:#3f3f46;">Activo (visible para empleados)</span>
  </label>

  <div class="flex items-center gap-3" style="padding-top:4px;">
    <%= f.submit certificate_type.new_record? ? "Crear Tipo" : "Actualizar Tipo",
                 class: "btn btn-violet" %>
    <%= link_to "Cancelar", admin_certificate_types_path, class: "btn btn-ghost" %>
  </div>
<% end %>
