<% content_for :title, "Certificados" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Mis certificados</h1>
    <p class="page-subtitle">Historial y estado de tus solicitudes</p>
  </div>
</div>

<% if @certificate_requests.present? %>
  <%# Summary cards %>
  <%
    active_count   = @certificate_requests.count { |r| !r.delivered? && !r.rejected? }
    ready_count    = @certificate_requests.count(&:ready?)
    overdue_count  = @certificate_requests.count(&:overdue?)
  %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="card stat-card">
      <p class="stat-value" style="color:#5b21b6;"><%= @certificate_requests.count %></p>
      <p class="stat-label">Total solicitudes</p>
    </div>
    <div class="card stat-card">
      <p class="stat-value" style="color:#1e40af;"><%= active_count %></p>
      <p class="stat-label">En proceso</p>
    </div>
    <div class="card stat-card">
      <p class="stat-value" style="color:#166534;"><%= ready_count %></p>
      <p class="stat-label">Listas</p>
    </div>
    <div class="card stat-card">
      <p class="stat-value" style="color:#991b1b;"><%= overdue_count %></p>
      <p class="stat-label">Vencidas</p>
    </div>
  </div>

  <div class="card overflow-hidden">
    <table class="data-table">
      <thead>
        <tr>
          <th>Referencia</th>
          <th>Tipo</th>
          <th>Estado</th>
          <th>Solicitado</th>
          <th>Fecha esperada</th>
        </tr>
      </thead>
      <tbody>
        <% @certificate_requests.each do |cr| %>
          <tr>
            <td>
              <%= link_to cr.reference_number, certificate_request_path(cr),
                    style: "font-weight:600; color:#7c3aed; font-size:13px; font-family:monospace;" %>
            </td>
            <td>
              <span style="font-size:13px; color:#3f3f46;"><%= cr.cert_type.humanize %></span>
            </td>
            <td>
              <% if cr.overdue? %>
                <span class="badge badge-failed">Vencida</span>
              <% else %>
                <span class="badge badge-<%= cr.status %>"><%= cr.human_status %></span>
              <% end %>
            </td>
            <td style="color:#71717a;"><%= l(cr.requested_at, format: :short) %></td>
            <td>
              <% if cr.expected_ready_at %>
                <span style="color:<%= cr.overdue? ? '#b91c1c' : '#71717a' %>">
                  <%= l(cr.expected_ready_at, format: :short) %>
                  <%= " (vencida)" if cr.overdue? %>
                </span>
              <% else %>
                <span style="color:#d4d4d8;">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if defined?(@pagy) && @pagy %>
    <div class="mt-8"><%== pagy_nav(@pagy) if @pagy.pages > 1 %></div>
  <% end %>
<% else %>
  <div class="empty-state">
    <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    <p class="empty-state-title">Sin solicitudes aún</p>
    <p class="empty-state-desc">Cuando solicites un certificado aparecerá aquí</p>
  </div>
<% end %>
