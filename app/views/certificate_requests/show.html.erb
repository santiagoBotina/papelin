<% content_for :title, "Solicitud #{@certificate_request.reference_number}" %>

<div class="max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Solicitud <%= @certificate_request.reference_number %></h1>
      <p class="text-sm text-gray-500"><%= @certificate_request.cert_type.humanize %></p>
    </div>
    <%= link_to certificate_requests_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      &larr; Volver
    <% end %>
  </div>

  <!-- Status card -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Estado</h2>
      <span class="<%= @certificate_request.overdue? ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %> text-sm px-3 py-1 rounded-full font-medium">
        <%= @certificate_request.human_status %>
      </span>
    </div>

    <div class="space-y-4">
      <div class="flex justify-between text-sm">
        <span class="text-gray-500">Fecha de solicitud</span>
        <span class="text-gray-900"><%= l(@certificate_request.requested_at, format: :long) %></span>
      </div>
      <% if @certificate_request.expected_ready_at %>
        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Fecha estimada de entrega</span>
          <span class="text-gray-900"><%= l(@certificate_request.expected_ready_at, format: :long) %></span>
        </div>
      <% end %>
      <% if @certificate_request.ready_at %>
        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Fecha de entrega</span>
          <span class="text-gray-900"><%= l(@certificate_request.ready_at, format: :long) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Notes -->
  <% if @certificate_request.notes.present? %>
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
      <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-3">Notas</h2>
      <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @certificate_request.notes %></p>
    </div>
  <% end %>

  <!-- Admin notes -->
  <% if @certificate_request.admin_notes.present? %>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-6">
      <h2 class="text-sm font-medium text-blue-800 uppercase tracking-wide mb-2">Nota de RRHH</h2>
      <p class="text-sm text-blue-900 whitespace-pre-wrap"><%= @certificate_request.admin_notes %></p>
    </div>
  <% end %>

  <!-- Download -->
  <% if @certificate_request.ready? && @certificate_request.generated_file.attached? %>
    <div class="bg-green-50 border border-green-200 rounded-xl p-6">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="font-medium text-green-800">Certificado listo para descargar</h3>
          <p class="text-sm text-green-600 mt-1">Tu certificado ya está disponible.</p>
        </div>
        <%= link_to "Descargar", rails_blob_path(@certificate_request.generated_file, disposition: "attachment"),
                    class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
