<%# local: message %>
<div id="<%= dom_id(message) %>"
     class="flex <%= message.user? ? 'justify-end' : 'justify-start' %>"
     style="animation: fadeUp 0.2s ease;">
  <div style="max-width: 76%;">

    <% if message.assistant? %>
      <div class="flex items-center gap-1.5 mb-1.5" style="font-size:11.5px; color:#a1a1aa; font-weight:500;">
        <div class="w-5 h-5 rounded-full flex items-center justify-center" style="background:#f5f3ff;">
          <svg class="w-3 h-3" style="color:#7c3aed;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
        </div>
        Pipelin AI
      </div>
    <% end %>

    <div style="<%= message.user? ?
          'background:#18181b; color:#fff; border-radius:18px 18px 4px 18px; padding:11px 16px;' :
          'background:#fafafa; border:1px solid #f0f0f2; color:#18181b; border-radius:18px 18px 18px 4px; padding:11px 16px;' %>">

      <div id="<%= "#{dom_id(message)}_content" %>" class="prose-chat" style="font-size:14px; line-height:1.6;">
        <% if message.pending? || message.streaming? %>
          <%= render "messages/loading" %>
        <% elsif message.failed? %>
          <span style="color:#e11d48; font-size:13px;">⚠ No se pudo generar una respuesta. Intenta de nuevo.</span>
        <% else %>
          <%= render_markdown(message.content) %>
        <% end %>
      </div>

      <% if message.sources.present? %>
        <div style="margin-top:10px; padding-top:8px; border-top:1px solid rgba(0,0,0,0.08);">
          <p style="font-size:11px; color:<%= message.user? ? 'rgba(255,255,255,0.5)' : '#a1a1aa' %>; font-weight:500; margin-bottom:4px; letter-spacing:0.04em; text-transform:uppercase;">Fuentes</p>
          <div class="flex flex-wrap gap-1.5">
            <% message.sources.each do |s| %>
              <span style="font-size:11px; padding:2px 8px; border-radius:999px; background:<%= message.user? ? 'rgba(255,255,255,0.15)' : '#ede9fe' %>; color:<%= message.user? ? '#fff' : '#5b21b6' %>;">
                <%= s["title"] %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>

<style>
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
