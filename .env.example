# Local development environment variables. Do NOT commit real secrets.
# These are placeholders consumed by config/database.yml, config/initializers/*, and credentials.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=papelin_dev
DATABASE_NAME_TEST=papelin_test

REDIS_URL=redis://localhost:6379/0

# Placeholder. Set the real value via Rails credentials or override here for local use.
OPENAI_API_KEY=sk-replace-me

# LocalStack (local dev S3 mock). No real credentials needed — LocalStack accepts any value.
AWS_ENDPOINT_URL=http://localhost:4566

# Production S3 — set real values in production environment / CI secrets.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=certificate-assistant-production
